#!/usr/bin/env node
// agent-diff-view — browser-based interactive git diff reviewer for AI coding agents.
//
// Opens a local browser UI where you annotate specific hunks with comments,
// then outputs a structured prompt to stdout and exits.
//
// Works with: Claude Code, OpenCode, Gemini CLI, Codex CLI (OpenAI), pi.dev
//
// Requires Node.js. No npm packages — only Node built-ins.
//
// Usage:
//   agent-diff-view install       # interactive harness picker
//   agent-diff-view               # diff against HEAD
//   agent-diff-view --cached      # staged changes
//   agent-diff-view main          # diff against branch or commit
//   agent-diff-view a..b          # range diff

'use strict';

const http             = require('http');
const fs               = require('fs');
const path             = require('path');
const { execFileSync } = require('child_process');
const { platform, homedir } = require('os');

// ── Harness definitions ──────────────────────────────────────────────────────

const CORE_INSTRUCTION = `This command opens a browser-based diff viewer — it **blocks intentionally** while the user annotates specific hunks with review comments. It exits on its own once they submit. Do not interrupt it or time out early.

When it exits, its stdout contains a structured prompt mapping each comment to its exact file and hunk. Address every comment in that output.`;

const HARNESSES = [
  {
    id: 'claude',
    label: 'Claude Code',
    dest: path.join(homedir(), '.claude', 'commands', 'changes.md'),
    content: `Execute \`npx agent-diff-view $ARGUMENTS\` using the bash tool and wait for it to exit.\n\n${CORE_INSTRUCTION}\n`,
  },
  {
    id: 'opencode',
    label: 'OpenCode',
    dest: path.join(homedir(), '.config', 'opencode', 'commands', 'changes.md'),
    content: `---\ndescription: Open interactive diff review in browser\n---\n\nExecute \`npx agent-diff-view $ARGUMENTS\` using the bash tool and wait for it to exit.\n\n${CORE_INSTRUCTION}\n`,
  },
  {
    id: 'gemini',
    label: 'Gemini CLI',
    dest: path.join(homedir(), '.gemini', 'commands', 'changes.toml'),
    content: `description = "Open interactive diff review in browser"\nprompt = """\nExecute the following command and wait for it to exit. Do not interrupt it or time out early — it opens a browser tab for interactive code review and blocks until the user submits.\n\n!{npx agent-diff-view {{args}}}\n\nThe output above contains a structured prompt mapping review comments to specific files and diff hunks. Address every comment in the output.\n"""\n`,
  },
  {
    id: 'openai',
    label: 'Codex CLI (OpenAI)',
    dest: path.join(homedir(), '.agents', 'skills', 'changes', 'SKILL.md'),
    content: `---\nname: changes\ndescription: Open interactive diff review in browser and address review comments\n---\n\nExecute \`npx agent-diff-view\` using bash and wait for it to exit.\n\n${CORE_INSTRUCTION}\n`,
    extra: [
      {
        dest: path.join(homedir(), '.agents', 'skills', 'changes', 'agents', 'openai.yaml'),
        content: `policy:\n  allow_implicit_invocation: false\n`,
      },
    ],
  },
  {
    id: 'pi',
    label: 'pi.dev',
    dest: path.join(homedir(), '.pi', 'agent', 'prompts', 'changes.md'),
    content: `---\ndescription: Open interactive diff review in browser\n---\n\nExecute \`npx agent-diff-view $ARGUMENTS\` using the bash tool and wait for it to exit.\n\n${CORE_INSTRUCTION}\n`,
  },
];

// ── Interactive harness picker ───────────────────────────────────────────────

function installInteractive() {
  return new Promise((resolve) => {
    let selected = 0;

    function render() {
      // Move cursor up to overwrite previous render (except first time)
      const lines = HARNESSES.length + 2; // heading + blank + items
      process.stderr.write(`\x1b[${lines}A`);
      process.stderr.write('\x1b[J'); // clear from cursor to end
      draw();
    }

    function draw() {
      process.stderr.write('\x1b[1mSelect your AI coding harness:\x1b[0m\n\n');
      for (let i = 0; i < HARNESSES.length; i++) {
        const cursor = i === selected ? '\x1b[36m  ❯ ' : '    ';
        const label = HARNESSES[i].label;
        const reset = '\x1b[0m';
        process.stderr.write(`${cursor}${label}${reset}\n`);
      }
    }

    if (!process.stdin.isTTY) {
      process.stderr.write('Non-interactive terminal. Run agent-diff-view install in a terminal.\n');
      process.exit(1);
    }

    // Initial draw
    draw();

    process.stdin.setRawMode(true);
    process.stdin.resume();
    process.stdin.setEncoding('utf8');

    process.stdin.on('data', (key) => {
      if (key === '\u0003' || key === 'q') { // Ctrl+C or q
        process.stdin.setRawMode(false);
        process.stderr.write('\nCancelled.\n');
        process.exit(0);
      }

      if (key === '\r' || key === '\n') { // Enter
        process.stdin.setRawMode(false);
        process.stdin.pause();
        const harness = HARNESSES[selected];
        fs.mkdirSync(path.dirname(harness.dest), { recursive: true });
        fs.writeFileSync(harness.dest, harness.content);
        if (harness.extra) {
          for (const file of harness.extra) {
            fs.mkdirSync(path.dirname(file.dest), { recursive: true });
            fs.writeFileSync(file.dest, file.content);
          }
        }
        const cmd = harness.id === 'openai' ? '$changes' : '/changes';
        process.stderr.write(`\n\x1b[32m✓\x1b[0m  Installed ${cmd} for ${harness.label} → ${harness.dest}\n`);
        resolve();
        return;
      }

      // Arrow keys come as escape sequences: \x1b[A (up), \x1b[B (down)
      if (key === '\x1b[A' && selected > 0) { selected--; render(); }
      if (key === '\x1b[B' && selected < HARNESSES.length - 1) { selected++; render(); }
    });
  });
}


// ── Diff Parser ───────────────────────────────────────────────────────────────

function parseDiff(diffText) {
  const files = [];
  const sections = diffText.split(/^diff --git /m).filter(s => s.trim());

  for (const section of sections) {
    const lines = section.split('\n');
    const headerMatch = lines[0].match(/^a\/(.+) b\/(.+)$/);
    if (!headerMatch) continue;

    const oldPath = headerMatch[1];
    const newPath = headerMatch[2];

    let status = 'modified';
    let displayPath = newPath;

    for (const line of lines) {
      if (line.startsWith('new file mode'))    { status = 'added';   break; }
      if (line.startsWith('deleted file mode')){ status = 'deleted'; displayPath = oldPath; break; }
      if (line.startsWith('rename '))          { status = 'renamed'; break; }
    }

    const hunks = [];
    let i = 0;
    while (i < lines.length && !lines[i].startsWith('@@')) i++;

    while (i < lines.length) {
      if (!lines[i].startsWith('@@')) { i++; continue; }

      const header = lines[i++];
      const beforeLines = [], afterLines = [];
      let hasMinus = false, hasPlus = false;

      while (i < lines.length && !lines[i].startsWith('@@') && !lines[i].startsWith('diff ')) {
        const l = lines[i++];
        if (l.startsWith('-') && !l.startsWith('---')) { beforeLines.push(l.slice(1)); hasMinus = true; }
        else if (l.startsWith('+') && !l.startsWith('+++')) { afterLines.push(l.slice(1)); hasPlus = true; }
        else if (l.startsWith(' ')) { beforeLines.push(l.slice(1)); afterLines.push(l.slice(1)); }
      }

      if (beforeLines.length || afterLines.length) {
        hunks.push({
          header,
          before: beforeLines.join('\n'),
          after:  afterLines.join('\n'),
          isPureAddition: !hasMinus && hasPlus,
          isPureDeletion:  hasMinus && !hasPlus,
        });
      }
    }

    if (hunks.length || status !== 'modified') {
      files.push({ path: displayPath, oldPath, status, hunks });
    }
  }

  return files;
}


// ── Prompt Builder ────────────────────────────────────────────────────────────

function buildPrompt(files, comments) {
  const sections = [];

  for (let fi = 0; fi < files.length; fi++) {
    const f = files[fi];
    for (let hi = 0; hi < f.hunks.length; hi++) {
      const comment = (comments[`${fi}:${hi}`] || '').trim();
      if (!comment) continue;

      const hunk = f.hunks[hi];
      const snippetLines = (hunk.after || hunk.before).split('\n');
      const snippet = snippetLines.length > 12
        ? snippetLines.slice(0, 12).join('\n') + '\n  ...'
        : snippetLines.join('\n');

      sections.push(
        `**${f.path}** \u2014 hunk ${hi + 1}/${f.hunks.length}: \`${hunk.header.trim()}\`\n` +
        '```\n' + snippet + '\n```\n' +
        `Comment: ${comment}`
      );
    }
  }

  if (!sections.length) return '';

  return 'Please review the following code changes and address my comments:\n\n' +
         sections.join('\n\n---\n\n');
}


// ── HTML UI ───────────────────────────────────────────────────────────────────

const HTML_PATH = path.join(__dirname, 'ui.html');
const HTML_TEMPLATE = fs.readFileSync(HTML_PATH, 'utf8');

// ── HTTP Server ───────────────────────────────────────────────────────────────

function openBrowser(url) {
  try {
    if (platform() === 'darwin')     execFileSync('open', [url]);
    else if (platform() === 'win32') execFileSync('cmd', ['/c', 'start', '', url]);
    else                             execFileSync('xdg-open', [url]);
  } catch { /* ignore */ }
}

function findFreePort() {
  return new Promise((resolve, reject) => {
    const srv = require('net').createServer();
    srv.listen(0, '127.0.0.1', () => {
      const port = srv.address().port;
      srv.close(() => resolve(port));
    });
    srv.on('error', reject);
  });
}

function startServer(html, port) {
  let resolveSubmit;
  const submitted = new Promise(r => { resolveSubmit = r; });

  const server = http.createServer((req, res) => {
    if (req.method === 'GET' && req.url === '/') {
      const body = Buffer.from(html, 'utf8');
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Content-Length': body.length });
      res.end(body);

    } else if (req.method === 'POST' && req.url === '/submit') {
      let raw = '';
      req.on('data', chunk => { raw += chunk; });
      req.on('end', () => {
        const { comments } = JSON.parse(raw);
        res.writeHead(200, { 'Content-Type': 'text/plain' });
        res.end('ok');
        // Resolve after the response is fully flushed
        setImmediate(() => resolveSubmit(comments));
      });

    } else {
      res.writeHead(404);
      res.end();
    }
  });

  server.listen(port, '127.0.0.1');
  return { server, submitted };
}


// ── Main ──────────────────────────────────────────────────────────────────────

async function main() {
  const args = process.argv.slice(2);

  if (args[0] === 'install') {
    await installInteractive();
    process.exit(0);
  }

  const diffArgs = args.length ? args : ['HEAD'];

  let diffText;
  try {
    diffText = execFileSync('git', ['diff', ...diffArgs], { encoding: 'utf8' });
  } catch (e) {
    process.stderr.write(`git diff failed:\n${e.stderr || e.message}\n`);
    process.exit(1);
  }

  if (!diffText.trim()) {
    process.stderr.write('No changes found.\n');
    process.exit(0);
  }

  const files = parseDiff(diffText);
  if (!files.length) {
    process.stderr.write('No parseable changes found (binary-only diff?).\n');
    process.exit(0);
  }

  const diffJson = JSON.stringify(files).replace(/<\//g, '<\\/');
  const html = HTML_TEMPLATE.replace('__DIFF_DATA__', () => diffJson);
  const port = await findFreePort();
  const url  = `http://127.0.0.1:${port}`;

  const { server, submitted } = startServer(html, port);

  const totalHunks = files.reduce((n, f) => n + f.hunks.length, 0);
  process.stderr.write(`  Reviewing ${files.length} file(s), ${totalHunks} hunk(s) → ${url}\n`);
  openBrowser(url);

  const comments = await submitted;
  server.close();

  const prompt = buildPrompt(files, comments);
  if (prompt) process.stdout.write(prompt + '\n');
}

main().catch(e => { process.stderr.write(e.message + '\n'); process.exit(1); });
